# Local: use +asyncpg. No Render, a URL interna costuma vir como postgresql:// — a API normaliza automaticamente.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taggy
JWT_SECRET=change-me-in-development
API_PORT=8000

# Google Cloud credentials para sync ANP via BigQuery.
# Cole o conteúdo JSON inteiro da service account (em uma linha):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# Dev local sem variável: rode `gcloud auth application-default login` e omita esta var.
GOOGLE_CREDENTIALS_JSON=

# Fonte dos fatores de emissão MCTI.
# Arquivo local (recomendado): coloque o xlsx em app/back/data/ e use file://.
# MCTI_EMISSION_FACTORS_URL=file:///app/data/ghg_protocol.xlsx
# URL HTTP (fallback):
# MCTI_EMISSION_FACTORS_URL=https://...
MCTI_EMISSION_FACTORS_URL=file:///app/data/ghg_protocol.xlsx

# Token Bearer da apibrasil.io para lookup de placa → veículo (DETRAN + FIPE).
# Obtenha em: https://app.apibrasil.io
APIBRASIL_TOKEN=